APP_NAME="Tuition Centre LMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.tld

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tuition
DB_USERNAME=tuition
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=r2
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=10080

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Cloudflare in front. Trust the proxy so $request->ip() returns the real client IP.
TRUSTED_PROXIES=*

# Mail can stay off until needed. The skeleton has no email features.
MAIL_MAILER=log
